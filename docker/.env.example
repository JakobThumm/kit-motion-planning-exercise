# Copy to .env and adjust. docker compose reads this automatically.

# Prebuilt core image tag on GHCR (pin per semester, e.g. 2026ss). Default: latest.
KIT_MP_TAG=latest

# DDS domain shared by all services (core / curobo / isaac). Keep them identical.
ROS_DOMAIN_ID=42

# X11 display for RViz / Isaac Sim GUI.
DISPLAY=:0

# NGC API key for pulling nvcr.io/nvidia/isaac-sim (advanced track only).
# Get one at https://ngc.nvidia.com ; then: docker login nvcr.io
NGC_API_KEY=

# Isaac Sim version (advanced track).
ISAAC_SIM_VERSION=4.5.0
